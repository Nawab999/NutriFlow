<%- include('../layouts/top') %>
<%- include('../partials/nav') %>
<%- include('../partials/alerts') %>

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">Personalised Meal Planning</p>
    <h1>Future&#8209;oriented<br>nutrition.</h1>
    <p class="lead">Explore nutrition-focused meals built around your health conditions, save favourites, track what you eat, and order — all in one place.</p>
    <div class="button-row">
      <a href="/meals" class="button">Browse Meals</a>
      <% if (currentUser) { %>
        <a href="/dashboard" class="button button-ghost">My Dashboard</a>
      <% } else { %>
        <a href="/register" class="button button-ghost">Get started free</a>
      <% } %>
    </div>
    <div class="hero-stats-inline">
      <div class="hsi"><strong><%= stats.mealCount.toLocaleString() %>+</strong><span>Meals available</span></div>
      <div class="hsi-sep"></div>
      <div class="hsi"><strong><%= stats.userCount.toLocaleString() %>+</strong><span>Members</span></div>
      <div class="hsi-sep"></div>
      <div class="hsi"><strong>5</strong><span>Health conditions</span></div>
    </div>
  </div>
  <div class="hero-aside">
    <div class="hero-features">
      <div class="feature-item">
        <span class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
        </span>
        <div><strong>Health-first meals</strong><p>Filtered by condition, sugar, salt, and temperature.</p></div>
      </div>
      <div class="feature-item">
        <span class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </span>
        <div><strong>Personalised picks</strong><p>Recommendations scored to your wellness goals.</p></div>
      </div>
      <div class="feature-item">
        <span class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </span>
        <div><strong>Weekly planner</strong><p>Plan breakfast, lunch and dinner for the whole week.</p></div>
      </div>
      <div class="feature-item">
        <span class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        </span>
        <div><strong>Easy ordering</strong><p>Add to cart, checkout, and track your orders.</p></div>
      </div>
    </div>
  </div>
</section>

<section class="section-card">
  <div class="section-header">
    <div><p class="eyebrow">Recently Added</p><h2>Featured Meals</h2></div>
    <a href="/meals" class="text-link">View all &rarr;</a>
  </div>
  <div class="card-grid">
    <% featuredMeals.forEach(meal => { %>
      <% const mealVisual = getMealVisual(meal); %>
      <article class="meal-card">
        <a href="/meals/<%= meal._id %>" class="meal-card-image-link">
          <div class="meal-card-image" style="<%= mealVisual.backgroundStyle %>">
            <img src="<%= mealVisual.imageUrl %>" alt="<%= meal.meal_name %>" loading="lazy" onerror="this.style.display='none'">
          </div>
        </a>
        <div class="meal-card-body">
          <div class="pill-row">
            <span class="pill pill-condition"><%= meal.disease_type %></span>
            <span class="pill pill-meta"><%= meal.sugar_level %> sugar</span>
          </div>
          <h3><a href="/meals/<%= meal._id %>"><%= meal.meal_name %></a></h3>
          <% if (meal.description) { %><p class="meal-desc"><%= meal.description.length > 80 ? meal.description.slice(0,80)+'…' : meal.description %></p><% } %>
          <div class="card-meta">
            <strong class="price-tag"><%= formatCurrency(meal.price) %></strong>
            <span class="cal-tag"><%= meal.calories||0 %> cal</span>
          </div>
          <div class="card-actions">
            <% if (currentUser) { %>
              <form method="POST" action="/cart/add" class="inline-form">
                <input type="hidden" name="mealId" value="<%= meal._id %>">
                <input type="hidden" name="quantity" value="1">
                <input type="hidden" name="redirectTo" value="/?message=Added+to+cart&type=success">
                <button type="submit" class="button button-small">Add to cart</button>
              </form>
            <% } else { %>
              <a href="/meals/<%= meal._id %>" class="button button-ghost button-small">View details</a>
            <% } %>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../layouts/bottom') %>
