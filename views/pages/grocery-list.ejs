<%- include('../layouts/top') %>
<%- include('../partials/nav') %>
<%- include('../partials/alerts') %>

<section class="section-card">
  <div class="section-header">
    <div>
      <p class="eyebrow">Cook Mode</p>
      <h1>Grocery List</h1>
      <p class="text-muted">Ingredients for each meal you're planning to cook.</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center">
      <button class="button button-ghost" onclick="window.print()">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:4px"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print
      </button>
      <a href="/meals" class="button button-ghost">← Browse Meals</a>
      <a href="/planner" class="button button-ghost">Planner</a>
    </div>
  </div>

  <% if (!hasPlan) { %>
  <div class="empty-state">
    <div class="empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--muted)"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
    </div>
    <p>Your grocery list is empty.</p>
    <p class="text-muted" style="font-size:0.85rem">Add meals from the planner or browse meals in Cook Mode and click "+ Grocery".</p>
    <div style="display:flex;gap:10px;justify-content:center;margin-top:12px">
      <a href="/meals" class="button">Browse Meals</a>
      <a href="/planner" class="button button-ghost">Go to Planner</a>
    </div>
  </div>
  <% } else { %>

  <!-- Summary bar -->
  <div class="grocery-summary">
    <div class="grocery-stat"><strong><%= mealCards.length %></strong><small>meal<%= mealCards.length !== 1 ? 's' : '' %></small></div>
    <div class="grocery-stat"><strong><%= mealCards.reduce((n, c) => n + c.ingredients.length, 0) %></strong><small>ingredients</small></div>
    <div class="grocery-stat">
      <button class="button button-ghost button-small" onclick="checkAll()">Check all</button>
    </div>
    <div class="grocery-stat">
      <button class="button button-ghost button-small" onclick="uncheckAll()">Uncheck all</button>
    </div>
  </div>

  <!-- Per-meal ingredient cards -->
  <div class="gl-cards" id="groceryList">
    <% let globalIdx = 0; %>
    <% mealCards.forEach(card => { %>
    <%
      const m = card.meal;
      const mealVisual = getMealVisual(m);
      const isSaved = card.source === 'saved';
    %>
    <div class="gl-card">
      <!-- Card header -->
      <div class="gl-card-header">
        <a href="/meals/<%= m._id %>" class="gl-card-img" style="<%= mealVisual.backgroundStyle %>">
          <img src="<%= mealVisual.imageUrl %>" alt="<%= m.meal_name %>" loading="lazy" onerror="this.style.display='none'">
        </a>
        <div class="gl-card-meta">
          <div class="gl-card-title-row">
            <a href="/meals/<%= m._id %>" class="gl-card-title"><%= m.meal_name %></a>
            <% if (isSaved) { %>
              <span class="gl-source-badge gl-source-saved">Saved</span>
            <% } else { %>
              <span class="gl-source-badge gl-source-planner">Planner</span>
            <% } %>
          </div>
          <div class="gl-card-stats">
            <% if (m.calories) { %><span><%= m.calories %> kcal</span><% } %>
            <% if (m.protein) { %><span><%= m.protein %>g protein</span><% } %>
            <% if (m.cookTime) { %><span><%= m.cookTime %> min</span><% } %>
            <span class="gl-ing-count"><%= card.ingredients.length %> ingredient<%= card.ingredients.length !== 1 ? 's' : '' %></span>
          </div>
        </div>
        <% if (isSaved) { %>
        <form method="POST" action="/grocery-list/remove" class="inline-form gl-remove-form">
          <input type="hidden" name="mealId" value="<%= m._id %>">
          <button type="submit" class="btn-remove-grocery" title="Remove from grocery list">&times;</button>
        </form>
        <% } %>
      </div>

      <!-- Ingredient checklist -->
      <% if (card.ingredients.length) { %>
      <ul class="gl-ingredients">
        <% card.ingredients.forEach(ing => {
          const idx = globalIdx++;
        %>
        <li class="gl-ing-item" id="gi-<%= idx %>">
          <label class="gl-ing-label">
            <input type="checkbox" class="grocery-cb" onchange="toggleItem(this, <%= idx %>)">
            <span class="gl-checkmark"></span>
            <span class="gl-ing-text"><%= ing %></span>
          </label>
        </li>
        <% }) %>
      </ul>
      <% } else { %>
      <p class="gl-no-ingredients">No ingredient data available for this meal.</p>
      <% } %>
    </div>
    <% }) %>
  </div>

  <% } %>
</section>

<%- include('../partials/footer') %>
<%- include('../layouts/bottom') %>

<script>
  function toggleItem(cb, idx) {
    document.getElementById('gi-' + idx).classList.toggle('gl-ing-done', cb.checked);
    saveState();
  }
  function checkAll() {
    document.querySelectorAll('.grocery-cb').forEach((cb, i) => {
      cb.checked = true;
      document.getElementById('gi-' + i).classList.add('gl-ing-done');
    });
    saveState();
  }
  function uncheckAll() {
    document.querySelectorAll('.grocery-cb').forEach((cb, i) => {
      cb.checked = false;
      document.getElementById('gi-' + i).classList.remove('gl-ing-done');
    });
    saveState();
  }
  function saveState() {
    const checked = [...document.querySelectorAll('.grocery-cb')].map(cb => cb.checked);
    try { localStorage.setItem('groceryChecked', JSON.stringify(checked)); } catch(e) {}
  }
  function restoreState() {
    try {
      const saved = JSON.parse(localStorage.getItem('groceryChecked') || '[]');
      document.querySelectorAll('.grocery-cb').forEach((cb, i) => {
        if (saved[i]) {
          cb.checked = true;
          document.getElementById('gi-' + i).classList.add('gl-ing-done');
        }
      });
    } catch(e) {}
  }
  restoreState();
</script>

<style>
@media print {
  .topbar, .nav-links, .section-header button, .section-header a,
  .grocery-summary button, footer, .gl-remove-form { display: none !important; }
  .gl-ing-done .gl-ing-text { text-decoration: line-through; color: #aaa; }
}
</style>
